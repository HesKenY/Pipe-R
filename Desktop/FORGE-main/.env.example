OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=forgeagent
SYSTEM_PROMPT=You are ForgeAgent, a highly capable local AI coding assistant. Use tools proactively to help the user.
TEMPERATURE=0.7
MAX_TOOL_ROUNDS=8
MAX_TOOL_CALLS_PER_TURN=4
DREAM_INTERVAL=10
MEMORY_DIR=.memory

# Optional: Anthropic API key for benchmarking against Claude Code
# Only used for "Benchmark vs Claude" — not required for normal operation
# ANTHROPIC_API_KEY=sk-ant-...
